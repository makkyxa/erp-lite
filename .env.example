# Environment settings (development, production, testing)
ENVIRONMENT=development

# Security
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=erp_lite
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Database URL for asyncpg connection (SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@postgres:5432/erp_lite

# CORS Settings (comma-separated list of origins)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
